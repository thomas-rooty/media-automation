# Copie ce fichier en `dashboard.env` et remplis les valeurs.

# --- General ---
# DASH_TITLE=CapyFlix Monitoring
# DASH_REFRESH_SECONDS=30

# --- Météo (Open-Meteo, sans clé) ---
# Astuce: tu peux récupérer lat/lon depuis Google Maps.
# DASH_WEATHER_LAT=48.8566
# DASH_WEATHER_LON=2.3522
# DASH_WEATHER_LABEL=Paris

# --- Sonarr ---
DASH_SONARR_URL=http://sonarr:8989
DASH_SONARR_API_KEY=CHANGE_ME

# --- Radarr ---
DASH_RADARR_URL=http://radarr:7878
DASH_RADARR_API_KEY=CHANGE_ME

# --- qBittorrent ---
# Dans ta stack, qBittorrent est derrière Gluetun -> gluetun:8080 sur le réseau Docker
DASH_QBITTORRENT_URL=http://gluetun:8080
DASH_QBITTORRENT_USERNAME=admin
DASH_QBITTORRENT_PASSWORD=adminadmin

# --- Jellyfin ---
DASH_JELLYFIN_URL=http://jellyfin:8096
# Optionnel mais souvent nécessaire pour /Users/{userId}/Items/Latest
# Trouve-le dans Jellyfin: Admin -> Utilisateurs -> (ton user) -> ID
# DASH_JELLYFIN_USER_ID=CHANGE_ME
DASH_JELLYFIN_API_KEY=CHANGE_ME

# --- Jellyseerr (ajout séries depuis le dashboard) ---
# DASH_JELLYSEERR_URL=http://jellyseerr:5055
# DASH_JELLYSEERR_API_KEY=CHANGE_ME

# --- Prowlarr ---
# DASH_PROWLARR_URL=http://prowlarr:9696
# DASH_PROWLARR_API_KEY=CHANGE_ME

# --- Bazarr ---
# DASH_BAZARR_URL=http://bazarr:6767

# --- FlareSolverr ---
# DASH_FLARESOLVERR_URL=http://flaresolverr:8191

# --- Autobrr ---
# DASH_AUTOBRR_URL=http://autobrr:7474

# --- Watcharr ---
# DASH_WATCHARR_URL=http://watcharr:3080

# --- Portainer ---
# DASH_PORTAINER_URL=http://portainer:9000

# --- Glances ---
# DASH_GLANCES_URL=http://glances:61208

# --- Dozzle ---
# DASH_DOZZLE_URL=http://dozzle:8080

# --- Nextcloud ---
# DASH_NEXTCLOUD_URL=http://nextcloud:80

# --- Gluetun (VPN control server, port 8000 par défaut) ---
# DASH_GLUETUN_URL=http://gluetun:8000

# --- Optionnel: liens (URLs LAN accessibles depuis la tablette) ---
# Exemple (remplace 192.168.1.10 par l'IP de ton serveur):
# DASH_LINKS_JSON=[{"label":"Jellyfin","url":"http://192.168.1.10:8096"},{"label":"Sonarr","url":"http://192.168.1.10:8989"},{"label":"qBittorrent","url":"http://192.168.1.10:8080"}]

# --- Optionnel: disques à afficher (chemins DANS le container) ---
# Exemple: si ton disque externe est monté dans un service via /mnt/medias, il faut aussi le monter dans le dashboard
# et mettre le chemin correspondant.
# DASH_DISKS_JSON=[{"label":"Système","path":"/"},{"label":"Disque externe","path":"/mnt/medias"}]
