# Identité du serveur
TZ=Europe/Paris
PUID=1000
PGID=1000
SERVER_IP=192.168.1.10

# AirVPN / WireGuard — valeurs fournies par AirVPN
WIREGUARD_PUBLIC_KEY=CHANGE_ME
WIREGUARD_PRIVATE_KEY=CHANGE_ME
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=CHANGE_ME
WIREGUARD_MTU=1320
SERVER_COUNTRIES=Netherlands
AIRVPN_PORT_FORWARD=6881

# qBittorrent
WEBUI_PORT=8080
QBIT_USER=admin
QBIT_PASS=CHANGE_ME
# Host HTTP présenté à qBittorrent depuis le dashboard. Ne le remplace pas par
# "gluetun" sauf si ce domaine est autorisé dans la WebUI qBittorrent.
QBIT_HOST=127.0.0.1

# Clés API des applications
PROWLARR_API_KEY=CHANGE_ME
SONARR_API_KEY=CHANGE_ME
SONARR_PRIVATE_API_KEY=CHANGE_ME
RADARR_API_KEY=CHANGE_ME
BAZARR_API_KEY=CHANGE_ME
JELLYFIN_API_KEY=CHANGE_ME
JELLYFIN_USER_ID=
JELLYSEERR_API_KEY=CHANGE_ME

# Dashboard
DASH_TITLE=CapyFlix
DASHBOARD_PORT=3000
DASH_REFRESH_SECONDS=30
WEATHER_LAT=48.8566
WEATHER_LON=2.3522
WEATHER_LABEL=Paris

# Tunnel Cloudflare
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME

# Compatibilité Watchtower avec Docker Engine 29+
DOCKER_API_VERSION=1.44
